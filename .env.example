GEMINI_API_KEY="MY_GEMINI_API_KEY"
APP_URL="MY_APP_URL"
VITE_REMOVE_BG_API_KEY="YOUR_REMOVE_BG_API_KEY"

# OpenAI (서버리스에서만 사용, 브라우저에 노출되지 않음)
OPENAIAPIKEY="sk-..."
OPENAI_TEXT_MODEL="gpt-4.1-mini"     # 기획안/카피 생성
OPENAI_IMAGE_MODEL="gpt-image-2"     # 이미지 생성 기본값, 필요 시 변경
OPENAI_IMAGE_QUALITY="medium"        # low | medium | high | auto

# Supabase (https://supabase.com 에서 프로젝트 생성 후 발급)
SUPABASE_URL="https://xxxxxxxxxxxx.supabase.co"
SUPABASE_SERVICE_KEY="eyJ..."   # Settings > API > service_role key

# JWT 서명 비밀키 (임의의 긴 문자열 사용)
JWT_SECRET="여기에-랜덤-긴-문자열-입력"

# 관리자 이메일 (이 이메일로 로그인하면 관리자 권한 부여)
ADMIN_EMAIL="admin@example.com"
