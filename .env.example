# OpenAI(GPT) — 상세페이지/썸네일 이미지 생성에 사용 (언더스코어 없는 이름)
OPENAIAPIKEY="sk-..."
# (선택) 이미지 모델 기본값: gpt-image-1-mini
OPENAI_IMAGE_MODEL="gpt-image-1-mini"

GEMINI_API_KEY="MY_GEMINI_API_KEY"
APP_URL="MY_APP_URL"
VITE_REMOVE_BG_API_KEY="YOUR_REMOVE_BG_API_KEY"

# Supabase (https://supabase.com 에서 프로젝트 생성 후 발급)
SUPABASE_URL="https://xxxxxxxxxxxx.supabase.co"
SUPABASE_SERVICE_KEY="eyJ..."   # Settings > API > service_role key

# JWT 서명 비밀키 (임의의 긴 문자열 사용)
JWT_SECRET="여기에-랜덤-긴-문자열-입력"

# 관리자 이메일 (이 이메일로 로그인하면 관리자 권한 부여)
ADMIN_EMAIL="admin@example.com"
